{
  "name": "exam-booking",
  "version": "1.0.0",
  "description": "Backend for platform that lets students book exam slots",
  "keywords": [
    "exam",
    "booking",
    "bakend",
    "node.js"
  ],
  "homepage": "https://github.com/Avvyyy/exam-booking#readme",
  "bugs": {
    "url": "https://github.com/Avvyyy/exam-booking/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Avvyyy/exam-booking.git"
  },
  "license": "ISC",
  "author": "Favour A. Uzochukwu",
  "type": "commonjs",
  "main": "app.js",
  "scripts": {
    "start": "node dist/app.js",
    "dev": "nodemon --exec ts-node src/app.ts",
    "build": "tsc",
    "postinstall": "prisma generate && npm run build",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:seed": "prisma db seed"
  },
  "prisma": {
    "seed": "node prisma/seed.js"
  },
  "dependencies": {
    "@prisma/client": "^7.4.2",
    "@types/express": "^5.0.3",
    "@types/node": "^24.3.1",
    "bcryptjs": "^3.0.2",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dayjs": "^1.11.18",
    "dotenv": "^17.2.0",
    "express": "^5.1.0",
    "joi": "^18.0.1",
    "jsonwebtoken": "^9.0.2",
    "nodemailer": "^7.0.5",
    "nodemon": "^3.1.10",
    "pg": "^8.20.0",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "ts-node": "^10.9.2"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/pg": "^8.15.5",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "prisma": "^7.4.2",
    "typescript": "^5.9.3"
  }
